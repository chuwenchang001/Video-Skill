# Video-Skill · 环境变量示例
# 复制为 .env 并填入真实值。真实 .env 已被 .gitignore 排除,切勿提交。
# 这些变量对应 Video Pipeline 四个 Skill 在运行时读取的配置。

# ── LLM(Skill 1 商品理解 / Skill 2 分镜脚本;OpenAI 兼容端点,可指向 BytePlus ModelArk)──
OPENAI_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3   # 缺省走 OpenAI 官方
OPENAI_API_KEY=sk-your-key-here                                  # LLM + 视频(Seedance)共用
OPENAI_MODEL=gpt-4o                                              # Skill 1/2 文本模型,默认 gpt-4o

# ── 视频生成(Skill 3 · 火山方舟 ModelArk Seedance 异步任务)──
VIDEO_MODEL=seedance-1-0-lite-t2v-250428                         # Seedance 视频模型
VIDEO_RESOLUTION=720p                                            # 480p / 720p / 1080p,默认 720p

# ── 多段拼接服务(Skill 3 · 30s 两段时用外部 FFmpeg 服务合成完整 mp4)──
STITCH_API_URL=https://your-stitch-service/api/stitch
STITCH_API_TOKEN=your-stitch-token

# ── 字幕烧制服务(Skill 4 · 外部 HTTP 服务)──
SUBTITLE_API_BASE=https://api.videodreamina.ai                   # 字幕烧制服务基址
SUBTITLE_STYLE=default                                           # 字幕样式
SUBTITLE_BURN_REQUIRED=false                                     # 烧字失败是否致命,默认 false(降级保留无字幕成片)

# ── 对象存储 TOS(成片持久化;未配置则暂存 Ark 临时 URL,约 24h 过期)──
TOS_ENDPOINT=tos-ap-southeast-1.bytepluses.com
TOS_REGION=ap-southeast-1
TOS_BUCKET=your-bucket
TOS_ACCESS_KEY=your-access-key
TOS_SECRET_KEY=your-secret-key
